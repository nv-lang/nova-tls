// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-tls: src/stream_leak_live_test_slow.nv — SLOW regression test for
// [M-187-sustained-live-tls-resource-death] (nova repo
// docs/simplifications.md; D376 slow-lane suffix — default `nova test`
// SKIPS this file; run via `--include-slow` / `--slow-only`). Lives
// directly beside the module (module-tests-beside-module convention),
// like every other test in this package — it did NOT used to: it lived in
// a separate `src/slow/` directory (own `module slow.*`) as a workaround
// for a confirmed compiler bug (peer-merge of a folder-module ignored the
// D376 `_slow` suffix — see the peer file `stream_leak_test_slow.nv`'s
// banner for the full diagnosis). FIXED: nova repo commit 252d81872
// (branch `p-fix-d376-peer-slow`, pending integrator merge to `main`) —
// [M-d376-slow-suffix-folder-module-peer-merge]. The workaround is lifted.
//
// That peer file is the DETERMINISTIC loopback signal; THIS file is the
// "as in production" variant requested by the owner: real internet TLS
// hosts, real `SystemRoots` verification (the actual `ClientConfig.new(host)`
// default the flagship aggregator uses against `api.open-meteo.com`), real
// per-connection handshake pump churn — but spread across a POOL of
// well-known, always-up, non-API domains so no single host sees more than
// `LEAK_LIVE_CONNS_PER_HOST` connections per run (politeness) and NO
// quota-bearing API (open-meteo etc.) is touched at all.
//
// Network-flaky-safe by design (D89/test-conventions honesty: "network
// unavailable" must never read as "leak found"): each connection attempt is
// independently fallible (DNS/connect/handshake failures just don't count),
// and the slope assertion only runs if at least `LEAK_LIVE_QUORUM_NUM /
// LEAK_LIVE_QUORUM_DEN` of the attempted connections actually succeeded —
// below quorum, the test prints a diagnostic and returns WITHOUT asserting
// (passes; this environment's network reachability is not what's under test).
//
// Root cause + fix + threshold rationale — see `stream_leak_test_slow.nv`'s
// banner (this file's peer) for the full diagnosis. This file's own
// calibration (`gc.heap_size()`-based slope over real internet handshakes,
// 40-host pool, `LEAK_LIVE_CONNS_PER_HOST = 2` => 80 real connections):
//   - post-fix (this commit): 3 stability runs, ALL 80/80 handshakes
//     succeeded, slope = 7777.90 bytes/ok-conn identically in every run
//     (fully deterministic given 80/80 success — no flakiness observed) —
//     far below `LEAK_LIVE_SLOPE_THRESHOLD_BYTES`.
// The threshold here is set LOOSER than the loopback test's (real hosts add
// DNS-resolution/connect-latency variance the loopback test doesn't have,
// and each real handshake exchanges a full certificate chain — bigger and
// more variable than the tiny fixture cert), but still comfortably below
// the loopback test's PRE-FIX rate (64094 bytes/iter) — a live-host slope
// anywhere near that old rate would still fail this test.

module tls

import std.net.{Net, TcpStream, resolve, real_net}
import std.runtime.gc

/// Real, well-known, always-up TLS hosts (port 443) — NOT open-meteo or any
/// quota-bearing API; ordinary web domains chosen for reachability + low
/// abuse-sensitivity at this volume (≤2 plain TLS handshakes each per run).
fn leak_live_hosts() -> []str {
    [
        "example.com", "example.org", "example.net", "wikipedia.org",
        "en.wikipedia.org", "cloudflare.com", "www.cloudflare.com",
        "github.com", "api.github.com", "raw.githubusercontent.com",
        "google.com", "www.google.com", "microsoft.com", "www.microsoft.com",
        "mozilla.org", "www.mozilla.org", "curl.se", "kernel.org",
        "python.org", "www.python.org", "rust-lang.org", "www.rust-lang.org",
        "nodejs.org", "apache.org", "debian.org", "ubuntu.com",
        "ietf.org", "w3.org", "gnu.org", "npmjs.com",
        "registry.npmjs.org", "pypi.org", "files.pythonhosted.org",
        "golang.org", "go.dev", "openssl.org", "eff.org", "archive.org",
        "duckduckgo.com", "bing.com",
    ]
}

const LEAK_LIVE_CONNS_PER_HOST int = 2   // politeness: at most 2 handshakes/host/run
const LEAK_LIVE_WARMUP_CONNS int = 10    // first-touch allocations, not sampled
const LEAK_LIVE_SAMPLE_EVERY_OK int = 5  // sample every 5th SUCCESSFUL connection
const LEAK_LIVE_QUORUM_NUM int = 6       // quorum = successes/attempts >= 6/10 (60%)
const LEAK_LIVE_QUORUM_DEN int = 10
// Looser than the loopback test (real-host variance) but still far below
// that test's measured pre-fix rate (64094 bytes/iter) — see banner above.
const LEAK_LIVE_SLOPE_THRESHOLD_BYTES f64 = 60000.0

// One real TLS handshake against `host:443` — connect, `ClientConfig.new(host)`
// (SystemRoots, the flagship's own default), handshake, close. No HTTP
// request needed: the leak is per-connection pump churn (handshake flights +
// close), not response-body volume — see stream.nv's flush_out/fill_from_tcp.
fn leak_live_one(host str) Net -> bool {
    match resolve(host, 443 as u16) {
        Err(_) => false
        Ok(addrs) => {
            if addrs.len() == 0 {
                false
            } else {
                match TcpStream.connect(addrs[0]) {
                    Err(_) => false
                    Ok(tcp) => {
                        ro cfg = ClientConfig.new(host)
                        match TlsStream.connect(tcp, cfg) {
                            Err(_) => false
                            Ok(session) => {
                                mut stream = session
                                stream.close()
                                true
                            }
                        }
                    }
                }
            }
        }
    }
}

test "SLOW: [M-187-sustained-live-tls-resource-death] live-host-pool TLS churn — GC-heap slope regression (real internet, no API quota)" {
    with Net = real_net() {
        // Real blocking Net I/O runs inside a fiber (`spawn`/`supervised`) —
        // matches every other real-network call site in this codebase
        // (aggregator's live.nv, this package's own smoke tests); calling
        // `Net`-effect functions directly from the test's root context hits
        // `nova_sched_park: invalid scope/slot` (confirmed empirically while
        // writing this test). All accumulator state stays LOCAL to the
        // spawned fiber (mut-capture across the spawn boundary would be
        // E_CONCURRENT_MUT_CAPTURE) — assert happens inside, same pattern as
        // this package's own smoke test (handshake_test.nv).
        supervised {
            spawn {
                ro hosts = leak_live_hosts()
                ro total = hosts.len() * LEAK_LIVE_CONNS_PER_HOST
                mut ok_count = 0
                mut sx f64 = 0.0
                mut sy f64 = 0.0
                mut sxy f64 = 0.0
                mut sxx f64 = 0.0
                mut n f64 = 0.0
                for idx in 0..total {
                    ro host = hosts[idx % hosts.len()]
                    ro succeeded = leak_live_one(host)
                    if succeeded {
                        ok_count += 1
                        if ok_count > LEAK_LIVE_WARMUP_CONNS && ok_count % LEAK_LIVE_SAMPLE_EVERY_OK == 0 {
                            gc.collect()
                            ro x = ok_count as f64
                            ro y = gc.heap_size() as f64
                            sx += x
                            sy += y
                            sxy += x * y
                            sxx += x * x
                            n += 1.0
                        }
                    }
                }
                println("[M-187-live] " + ok_count.to_str() + "/" + total.to_str() + " handshakes succeeded")
                // Quorum gate: below quorum, this environment's network
                // reachability is what failed, NOT the leak fix — pass
                // without asserting rather than reporting a false
                // leak-regression FAIL (test-conventions honesty:
                // network-down != leak).
                if ok_count * LEAK_LIVE_QUORUM_DEN < total * LEAK_LIVE_QUORUM_NUM {
                    println("[M-187-live] SKIP-equivalent: quorum not met (" + ok_count.to_str() +
                        "/" + total.to_str() + " < " + LEAK_LIVE_QUORUM_NUM.to_str() + "/" +
                        LEAK_LIVE_QUORUM_DEN.to_str() + ") — network reachability, not a leak signal; not asserting")
                } else if n < 2.0 {
                    println("[M-187-live] not enough post-warmup samples (n=" + n.to_str() +
                        ") to compute a slope — not asserting")
                } else {
                    ro slope = (n * sxy - sx * sy) / (n * sxx - sx * sx)
                    println("[M-187-live] GC-heap slope = " + slope.to_str() + " bytes/ok-conn (threshold " +
                        LEAK_LIVE_SLOPE_THRESHOLD_BYTES.to_str() + ")")
                    assert(slope < LEAK_LIVE_SLOPE_THRESHOLD_BYTES)
                }
            }
        }
    }
}
