// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-tls: конфиги — конструкторы, мутирующие беглые свойства
// (`mut @x(v) -> @`, D117 AMEND-2/D409 — см. config.nv), TlsVersion.
// Pure data — без сети/эффектов/шима. Extracted from monorepo std/tls
// (Plan 193 Ф.1).
//
// ro-байндинг перед .method() — обход [M-176-xmod-payload-variant-ctor]
// (см. error_test.nv).

module tls.tls

test "ClientConfig.new — дефолты: SNI, SystemRoots, alpn http/1.1" {
    ro cfg = ClientConfig.new("api.example.com")
    assert(cfg.server_name == "api.example.com")
    assert(cfg.alpn_protocols.len() == 1)
    assert(cfg.alpn_protocols[0] == "http/1.1")
    assert(match cfg.verification { SystemRoots => true, _ => false })
}

test "ClientConfig @alpn_protocols — мутирующее беглое свойство" {
    mut cfg = ClientConfig.new("example.com")
    cfg.alpn_protocols(["h2", "http/1.1"])
    assert(cfg.alpn_protocols.len() == 2)
    assert(cfg.alpn_protocols[0] == "h2")
    assert(cfg.server_name == "example.com")       // остальные поля не задеты
}

test "ClientConfig @verification — мутирующее беглое свойство, каждый режим" {
    mut cfg = ClientConfig.new("example.com")
    cfg.verification(VerificationMode.CustomRoots("PEM".bytes()))
    assert(match cfg.verification { CustomRoots(b) => b.len() == 3, _ => false })
    cfg.verification(VerificationMode.InsecureSkipVerify)
    assert(match cfg.verification { InsecureSkipVerify => true, _ => false })
    // §28: литерал вместо `.of`; байтовые данные (пин = хеш) — `x"..."` (D412)
    // вместо ASCII-плейсхолдера через `.bytes()`.
    ro pins = [x"01 23 45 67 89 ab cd ef 01 23 45 67 89 ab cd ef 01 23 45 67 89 ab cd ef 01 23 45 67 89 ab cd ef"]   // 32 байта
    cfg.verification(VerificationMode.Pinned(pins))
    assert(match cfg.verification { Pinned(hs) => hs.len() == 1, _ => false })
}

test "ServerConfig.new + @alpn_protocols + @client_cert (мутирующие беглые свойства)" {
    mut cfg = ServerConfig.new("CERT".bytes(), "KEY".bytes())
    assert(cfg.cert_pem.len() == 4)
    assert(cfg.key_pem.len() == 3)
    assert(cfg.alpn_protocols.len() == 0)
    assert(match cfg.client_cert { NoClientAuth => true, _ => false })

    cfg.alpn_protocols(["http/1.1"])
    assert(cfg.alpn_protocols.len() == 1)
    assert(cfg.cert_pem.len() == 4)                // остальные поля не задеты

    cfg.client_cert(ClientCertMode.Required("CA".bytes()))
    assert(match cfg.client_cert { Required(ca) => ca.len() == 2, _ => false })
    cfg.client_cert(ClientCertMode.Optional("CA".bytes()))
    assert(match cfg.client_cert { Optional(_) => true, _ => false })
}

test "TlsVersion — to_str + from_wire (0x0303/0x0304)" {
    ro v12 = TlsVersion.Tls12
    assert(v12.to_str() == "tls 1.2")
    ro v13 = TlsVersion.Tls13
    assert(v13.to_str() == "tls 1.3")
    assert(match TlsVersion.from_wire(771) { Some(v) => match v { Tls12 => true, _ => false }, None => false })
    assert(match TlsVersion.from_wire(772) { Some(v) => match v { Tls13 => true, _ => false }, None => false })
    assert(match TlsVersion.from_wire(0) { None => true, _ => false })
    assert(match TlsVersion.from_wire(769) { None => true, _ => false })  // TLS 1.0 — отвергнута by design
}
