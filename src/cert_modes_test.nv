// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-tls: режимы верификации + ALPN-негоциация на loopback-паре (real_net).
// Extracted from monorepo std/tls (Plan 193 Ф.1). Хелперы
// (must_tls/fixture_cert/fixture_key) — из handshake_test.nv
// (тот же folder-CU модуля tls).
//
// SPKI-пин localhost_cert.pem (SHA-256 SubjectPublicKeyInfo) — вычислен
// openssl'ом и cross-checked против shim `spki_pin` (native/tls_c_shim.c):
// при смене fixture пин обновить (пересчитать openssl x509 -pubkey | pkey
// -pubin -outform der | dgst -sha256).

module tls

import std.net.{Net, TcpListener, TcpStream, SocketAddr, NetError, real_net}

// SPKI SHA-256 пин фикстуры localhost_cert.pem (32 байта).
fn fixture_pin() -> []u8 =>
    x"92 f7 09 93 97 e8 c4 80 7a 31 10 0b f3 b7 b7 94 01 17 0a 13 85 1c 92 c9 fe d5 9d e4 92 cf 2c 34"

// ─── Pinned (SPKI SHA-256) ─────────────────────────────────────────────────────

test "T4-Pinned: правильный SPKI-пин — рукопожатие проходит" {
    with Net = real_net() {
        ro ch_port = Channel.new(1)
        supervised {
            spawn {
                consume lst = TcpListener.bind(SocketAddr.loopback(0))!!
                ch_port.tx.send(lst.local_port())
                ro accepted = lst.accept()
                lst.close()
                mut conn = accepted!!
                ro scfg = ServerConfig.new(fixture_cert(), fixture_key())
                consume tls = must_tls(TlsStream.accept(conn, scfg))
                tls.close()
            }
            spawn {
                ro port = match ch_port.rx.recv() { Some(p) => p  None => 0 as u16 }
                assert(port > 0)
                consume conn = TcpStream.connect(SocketAddr.loopback(port))!!
                ro pins = Vec[[]u8].of(fixture_pin())
                ro ccfg = ClientConfig.new("localhost")
                    .verification(VerificationMode.Pinned(pins))
                consume tls = must_tls(TlsStream.connect(conn, ccfg))
                tls.close()
            }
        }
    }
}

test "T4-Pinned-NEG: неверный пин — клиент отвергает серт, сервер тоже падает" {
    with Net = real_net() {
        ro ch_port = Channel.new(1)
        supervised {
            spawn {
                consume lst = TcpListener.bind(SocketAddr.loopback(0))!!
                ch_port.tx.send(lst.local_port())
                ro accepted = lst.accept()
                lst.close()
                mut conn = accepted!!
                ro scfg = ServerConfig.new(fixture_cert(), fixture_key())
                match TlsStream.accept(conn, scfg) {
                    Ok(consume s)  => { s.close() assert(false) }
                    Err(_) => {}
                }
            }
            spawn {
                ro port = match ch_port.rx.recv() { Some(p) => p  None => 0 as u16 }
                assert(port > 0)
                consume conn = TcpStream.connect(SocketAddr.loopback(port))!!
                ro pins = Vec[[]u8].of(x"00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00")
                ro ccfg = ClientConfig.new("localhost")
                    .verification(VerificationMode.Pinned(pins))
                match TlsStream.connect(conn, ccfg) {
                    Ok(consume s)  => { s.close() assert(false) }
                    Err(e) => {
                        assert(match e {
                            CertificateInvalid(_) => true
                            HandshakeFailure(_)   => true   // alert-тайминг
                            _ => false
                        })
                    }
                }
            }
        }
    }
}

test "T4-Pinned: пиннинг заменяет hostname-проверку — неверный SNI ОК при верном пине" {
    with Net = real_net() {
        ro ch_port = Channel.new(1)
        supervised {
            spawn {
                consume lst = TcpListener.bind(SocketAddr.loopback(0))!!
                ch_port.tx.send(lst.local_port())
                ro accepted = lst.accept()
                lst.close()
                mut conn = accepted!!
                ro scfg = ServerConfig.new(fixture_cert(), fixture_key())
                consume tls = must_tls(TlsStream.accept(conn, scfg))
                tls.close()
            }
            spawn {
                ro port = match ch_port.rx.recv() { Some(p) => p  None => 0 as u16 }
                assert(port > 0)
                consume conn = TcpStream.connect(SocketAddr.loopback(port))!!
                ro pins = Vec[[]u8].of(fixture_pin())
                // wrong.example НЕ покрыт сертом, но при Pinned hostname не проверяется.
                ro ccfg = ClientConfig.new("wrong.example")
                    .verification(VerificationMode.Pinned(pins))
                consume tls = must_tls(TlsStream.connect(conn, ccfg))
                tls.close()
            }
        }
    }
}

// ─── SystemRoots vs self-signed ───────────────────────────────────────────────

test "T4-SystemRoots-NEG: self-signed серт не в root-роутах → CertificateInvalid" {
    with Net = real_net() {
        ro ch_port = Channel.new(1)
        supervised {
            spawn {
                consume lst = TcpListener.bind(SocketAddr.loopback(0))!!
                ch_port.tx.send(lst.local_port())
                ro accepted = lst.accept()
                lst.close()
                mut conn = accepted!!
                ro scfg = ServerConfig.new(fixture_cert(), fixture_key())
                match TlsStream.accept(conn, scfg) {
                    Ok(consume s)  => { s.close() assert(false) }
                    Err(_) => {}
                }
            }
            spawn {
                ro port = match ch_port.rx.recv() { Some(p) => p  None => 0 as u16 }
                assert(port > 0)
                consume conn = TcpStream.connect(SocketAddr.loopback(port))!!
                // Дефолтный ClientConfig.new = SystemRoots (Mozilla bundle) —
                // самоподписанный серт там отсутствует.
                ro ccfg = ClientConfig.new("localhost")
                match TlsStream.connect(conn, ccfg) {
                    Ok(consume s)  => { s.close() assert(false) }
                    Err(e) => {
                        assert(match e {
                            CertificateInvalid(_) => true
                            HandshakeFailure(_)   => true
                            _ => false
                        })
                    }
                }
            }
        }
    }
}

// ─── ALPN негоциация ──────────────────────────────────────────────────────────

test "T4-ALPN: пересечение выбирает общий протокол (h2/http1.1 → http/1.1)" {
    with Net = real_net() {
        ro ch_port = Channel.new(1)
        supervised {
            spawn {
                consume lst = TcpListener.bind(SocketAddr.loopback(0))!!
                ch_port.tx.send(lst.local_port())
                ro accepted = lst.accept()
                lst.close()
                mut conn = accepted!!
                // Сервер поддерживает только http/1.1.
                ro scfg = ServerConfig.new(fixture_cert(), fixture_key()).alpn_protocols(["http/1.1"])
                consume tls = must_tls(TlsStream.accept(conn, scfg))
                tls.close()
            }
            spawn {
                ro port = match ch_port.rx.recv() { Some(p) => p  None => 0 as u16 }
                assert(port > 0)
                consume conn = TcpStream.connect(SocketAddr.loopback(port))!!
                // Клиент предпочитает h2, но принимает http/1.1.
                ro ccfg = ClientConfig.new("localhost")
                    .verification(VerificationMode.CustomRoots(fixture_cert()))
                    .alpn_protocols(["h2", "http/1.1"])
                consume tls = must_tls(TlsStream.connect(conn, ccfg))
                ro alpn = tls.alpn_negotiated()
                tls.close()
                assert(match alpn { Some(p) => p == "http/1.1", None => false })
            }
        }
    }
}

test "T4-ALPN-NEG: непересекающиеся списки → handshake fails (AlpnNoCommonProtocol)" {
    with Net = real_net() {
        ro ch_port = Channel.new(1)
        supervised {
            spawn {
                consume lst = TcpListener.bind(SocketAddr.loopback(0))!!
                ch_port.tx.send(lst.local_port())
                ro accepted = lst.accept()
                lst.close()
                mut conn = accepted!!
                ro scfg = ServerConfig.new(fixture_cert(), fixture_key()).alpn_protocols(["http/1.1"])
                // Сервер шлёт no_application_protocol alert → accept тоже Err.
                match TlsStream.accept(conn, scfg) {
                    Ok(consume s)  => { s.close() assert(false) }
                    Err(_) => {}
                }
            }
            spawn {
                ro port = match ch_port.rx.recv() { Some(p) => p  None => 0 as u16 }
                assert(port > 0)
                consume conn = TcpStream.connect(SocketAddr.loopback(port))!!
                ro ccfg = ClientConfig.new("localhost")
                    .verification(VerificationMode.CustomRoots(fixture_cert()))
                    .alpn_protocols(["h2"])   // только h2, сервер только http/1.1
                match TlsStream.connect(conn, ccfg) {
                    Ok(consume s)  => { s.close() assert(false) }
                    Err(e) => {
                        assert(match e {
                            AlpnNoCommonProtocol => true
                            HandshakeFailure(_)  => true
                            PeerMisbehaved(_)    => true
                            _ => false
                        })
                    }
                }
            }
        }
    }
}
