// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-tls: сквозная проверка «Nova → C → native/tls_c_shim.c (mbedTLS)».
// Extracted from monorepo std/tls (Plan 193 Ф.1). Первый CU, реально
// ВЫЗЫВАЮЩИЙ tls_*-символы → драйвит условную линковку шима (D337 mechanism).
//
// Ассерты пинят поведение РЕАЛЬНОГО mbedTLS (коды -12/INVALID_SNI, ClientHello
// в wants_write) — под Q11-заглушкой (хоста без установленного mbedTLS) тест
// честно упадёт, как и задумано: заглушка — для НЕ-tls программ и degrade-
// сценариев, не для tls-тестов.
//
// Никакой сети: рукопожатие не завершается — только конфиг, сессия и первый
// flight из state machine (sans-I/O).

module tls

test "link: bad-SNI отвергается реальным шимом кодом INVALID_SNI (-12)" {
    ro c = tls_client_cfg_new()
    assert((c as int) != 0)                     // билдер создан (не заглушка)
    assert(tls_cfg_verify_system(c) == 0)
    ro sni = "bad name!".bytes()                // пробел и '!' — не DNS-имя
    mut err int = 0
    ro h = unsafe { tls_client_new(c, sni.ptr(), sni.len(), &err) }
    assert((h as int) == 0)
    assert(err == -12)                          // TLS_ERR_INVALID_SNI
}

test "link: клиентская сессия строится; state machine хочет слать ClientHello" {
    ro c = tls_client_cfg_new()
    assert(tls_cfg_verify_system(c) == 0)
    ro proto = "http/1.1".bytes()
    assert(unsafe { tls_cfg_alpn_add(c, proto.ptr(), proto.len()) } == 0)
    ro sni = "example.com".bytes()
    mut err int = 0
    ro h = unsafe { tls_client_new(c, sni.ptr(), sni.len(), &err) }
    assert((h as int) != 0)
    assert(tls_is_handshaking(h) == 1)
    assert(tls_wants_write(h) == 1)             // ClientHello готов
    mut buf []u8 = []u8.new()
    buf.resize(4096, 0 as u8)
    ro n = unsafe { tls_write_tls(h, buf.ptr(), buf.len()) }
    assert(n > 0)                               // первый flight извлечён
    assert(tls_version(h) == 0)                 // версия ещё не согласована
    tls_free(h)
}

test "link: кривой PEM классифицируется INVALID_PEM (-10) через error-канал" {
    ro c = tls_client_cfg_new()
    ro pem = "not a pem".bytes()
    assert(unsafe { tls_cfg_verify_pem(c, pem.ptr(), pem.len()) } == 0)  // байты приняты
    ro sni = "example.com".bytes()
    mut err int = 0
    ro h = unsafe { tls_client_new(c, sni.ptr(), sni.len(), &err) }      // parse на build
    assert((h as int) == 0)
    assert(err == -10)                          // TLS_ERR_INVALID_PEM
    // from_shim замыкает канал в typed-ошибку:
    ro e = TlsError.from_shim(err, "no certificates found in PEM")
    assert(match e { InvalidPem(_) => true, _ => false })
}
