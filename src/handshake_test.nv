// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-tls: smoke — self-signed пара client↔server на loopback (real_net):
// рукопожатие, шифрованный round-trip, ALPN/версия, close, и негатив
// hostname-mismatch. Extracted from monorepo std/tls (Plan 193 Ф.1). Паттерн
// клиент/сервер — std/net/stress_test.nv (порт через buffered-канал; каждый
// сокет создаётся В СВОЕЙ фибре — loop-affinity контракт net.c).
//
// Fixtures: testdata/localhost_{cert,key}.pem — self-signed ECDSA P-256,
// CN=localhost, SAN DNS:localhost+IP:127.0.0.1, срок 100 лет (сгенерированы
// openssl, README рядом). Встраиваются через embed (D412) — без Fs-эффекта
// в тестах.

module tls

import std.net.{Net, TcpListener, TcpStream, SocketAddr, NetError, real_net}

// `panic` (used below) is an always-available compiler intrinsic
// ([panic-assert-intrinsic]) — resolved with no import/redeclaration needed,
// including when this file's bodies are compiled as a dependency of an
// external importer of `tls`.

fn fixture_cert() -> []u8 => embed("testdata/localhost_cert.pem")
fn fixture_key() -> []u8 => embed("testdata/localhost_key.pem")



fn must_tls(r Result[TlsStream, TlsError]) -> TlsStream {
    match r {
        Ok(s)  => s
        Err(e) => panic("tls failed: ${e.to_str()}")
    }
}

test "smoke: self-signed пара — handshake + шифрованный echo + ALPN + close" {
    with Net = real_net() {
        ro ch_port = Channel.new(1)
        supervised {
            // Сервер: bind в своей фибре, порт в канал, один accept + TLS + echo.
            spawn {
                consume lst = TcpListener.bind(SocketAddr.loopback(0))!!
                ch_port.tx.send(lst.local_port())
                // Один accept → listener можно закрыть сразу (D133: panic-арм
                // ниже не снимал бы его обязательство).
                ro accepted = lst.accept()
                lst.close()
                consume conn = accepted!!
                ro scfg = ServerConfig.new(fixture_cert(), fixture_key()).alpn_protocols(["http/1.1"])
                consume tls = must_tls(TlsStream.accept(conn, scfg))
                // D133: panic-арм не снимает consume-обязательство → ошибки
                // сворачиваются в сентинелы, assert'ы ПОСЛЕ close.
                ro got = match tls.read_to_vec(256) {
                    Ok(b)  => b
                    Err(_) => []u8.new()
                }
                ro wrote = match tls.write_all(got) {
                    Ok(_)  => true
                    Err(_) => false
                }
                tls.close()
                assert(got.len() == 12)
                assert(wrote)
            }
            // Клиент: CustomRoots на самоподписанный серт + SNI localhost.
            spawn {
                ro port = match ch_port.rx.recv() { Some(p) => p  None => 0 as u16 }
                assert(port > 0)
                consume conn = TcpStream.connect(SocketAddr.loopback(port))!!
                ro ccfg = ClientConfig.new("localhost")
                    .verification(VerificationMode.CustomRoots(fixture_cert()))
                consume tls = must_tls(TlsStream.connect(conn, ccfg))
                // Инспекция после handshake: версия согласована, ALPN сошёлся.
                assert(match tls.protocol_version() {
                    Some(_) => true
                    None    => false
                })
                assert(match tls.alpn_negotiated() {
                    Some(p) => p == "http/1.1"
                    None    => false
                })
                assert(tls.cipher_suite().byte_len() > 0)
                // Leaf-серт peer'а доступен как DER.
                assert(match tls.peer_cert_der(0) {
                    Some(der) => der.len() > 100
                    None      => false
                })
                ro wrote = match tls.write_all("hello, tls!!".bytes()) {
                    Ok(_)  => true
                    Err(_) => false
                }
                ro echo = match tls.read_to_vec(256) {
                    Ok(b)  => b
                    Err(_) => []u8.new()
                }
                tls.close()
                assert(wrote)
                assert(echo.len() == 12)
                assert(unsafe { echo.to_str_unchecked() } == "hello, tls!!")
            }
        }
    }
}

test "NEG-runtime: SNI не совпадает с сертом → HostnameMismatch, сервер тоже падает" {
    with Net = real_net() {
        ro ch_port = Channel.new(1)
        supervised {
            spawn {
                consume lst = TcpListener.bind(SocketAddr.loopback(0))!!
                ch_port.tx.send(lst.local_port())
                ro accepted = lst.accept()
                lst.close()
                consume conn = accepted!!
                ro scfg = ServerConfig.new(fixture_cert(), fixture_key())
                // Клиент отвергнет наш серт (bad_certificate alert) → Err;
                // точный вариант зависит от тайминга alert vs reset — важно,
                // что это ошибка и ресурсы прибраны (обязательства сняты).
                match TlsStream.accept(conn, scfg) {
                    Ok(s)  => {
                        s.close()
                        assert(false)
                    }
                    Err(_) => {}
                }
            }
            spawn {
                ro port = match ch_port.rx.recv() { Some(p) => p  None => 0 as u16 }
                assert(port > 0)
                consume conn = TcpStream.connect(SocketAddr.loopback(port))!!
                // Серт покрывает ТОЛЬКО localhost/127.0.0.1 — wrong.example не пройдёт.
                ro ccfg = ClientConfig.new("wrong.example")
                    .verification(VerificationMode.CustomRoots(fixture_cert()))
                match TlsStream.connect(conn, ccfg) {
                    Ok(s)  => {
                        s.close()
                        assert(false)
                    }
                    Err(e) => {
                        assert(match e {
                            HostnameMismatch(_) => true
                            _ => false
                        })
                    }
                }
            }
        }
    }
}

test "NEG-runtime: пустой SNI отвергается ДО сокет-трафика; мусорный PEM у сервера" {
    with Net = real_net() {
        supervised {
            spawn {
                // Пустое имя: сокет закрывается внутри, ошибка типизирована.
                consume lst = TcpListener.bind(SocketAddr.loopback(0))!!
                ro port = lst.local_port()
                consume conn = TcpStream.connect(SocketAddr.loopback(port))!!
                ro ccfg = ClientConfig.new("")
                match TlsStream.connect(conn, ccfg) {
                    Ok(s)  => {
                        s.close()
                        assert(false)
                    }
                    Err(e) => {
                        assert(match e {
                            InvalidServerName(_) => true
                            _ => false
                        })
                    }
                }
                // Мусорный PEM: server-конфиг отвергается до handshake.
                consume conn2 = TcpStream.connect(SocketAddr.loopback(port))!!
                ro scfg = ServerConfig.new("not a pem".bytes(), "not a key".bytes())
                match TlsStream.accept(conn2, scfg) {
                    Ok(s)  => {
                        s.close()
                        assert(false)
                    }
                    Err(e) => {
                        assert(match e {
                            InvalidPem(_) => true
                            _ => false
                        })
                    }
                }
                lst.close()
            }
        }
    }
}
