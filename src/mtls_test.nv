// SPDX-License-Identifier: MIT OR Apache-2.0
// nova-tls: mutual TLS — server ClientCertMode + client-side серт.
// Extracted from monorepo std/tls (Plan 193 Ф.1). Хелперы из
// handshake_test.nv (тот же folder-CU).
//
// Fixtures (testdata/): client_ca_cert.pem (клиентский CA, CA:TRUE) +
// client_cert.pem/client_key.pem (leaf, EKU=clientAuth). Сервер доверяет CA;
// клиент предъявляет leaf.

module tls.tls

import std.net.{Net, TcpListener, TcpStream, SocketAddr, NetError, real_net}

fn client_ca() -> []u8 => embed("testdata/client_ca_cert.pem")
fn client_leaf() -> []u8 => embed("testdata/client_cert.pem")
fn client_leaf_key() -> []u8 => embed("testdata/client_key.pem")

test "T5-Required: клиент предъявляет валидный серт → mTLS-рукопожатие OK" {
    with Net = real_net() {
        ro ch_port = Channel.new(1)
        supervised {
            spawn {
                consume lst = must_listener(TcpListener.bind(SocketAddr.loopback(0)))
                ch_port.tx.send(lst.local_port())
                ro accepted = lst.accept()
                lst.close()
                consume conn = must_tcp(accepted)
                ro scfg = ServerConfig.new(fixture_cert(), fixture_key())
                    .client_cert(ClientCertMode.Required(client_ca()))
                consume tls = must_tls(TlsStream.accept(conn, scfg))
                tls.close()
            }
            spawn {
                ro port = match ch_port.rx.recv() { Some(p) => p  None => 0 as u16 }
                assert(port > 0)
                consume conn = must_tcp(TcpStream.connect(SocketAddr.loopback(port)))
                ro ccfg = ClientConfig.new("localhost")
                    .verification(VerificationMode.CustomRoots(fixture_cert()))
                    .client_cert(client_leaf(), client_leaf_key())
                consume tls = must_tls(TlsStream.connect(conn, ccfg))
                tls.close()
            }
        }
    }
}

test "T5-Required-NEG: клиент БЕЗ серта → сервер отвергает рукопожатие" {
    with Net = real_net() {
        ro ch_port = Channel.new(1)
        supervised {
            spawn {
                consume lst = must_listener(TcpListener.bind(SocketAddr.loopback(0)))
                ch_port.tx.send(lst.local_port())
                ro accepted = lst.accept()
                lst.close()
                consume conn = must_tcp(accepted)
                ro scfg = ServerConfig.new(fixture_cert(), fixture_key())
                    .client_cert(ClientCertMode.Required(client_ca()))
                // Клиент не шлёт серт → сервер шлёт certificate_required alert → Err.
                match TlsStream.accept(conn, scfg) {
                    Ok(s)  => { s.close() assert(false) }
                    Err(_) => {}
                }
            }
            spawn {
                ro port = match ch_port.rx.recv() { Some(p) => p  None => 0 as u16 }
                assert(port > 0)
                consume conn = must_tcp(TcpStream.connect(SocketAddr.loopback(port)))
                // Без client_cert — клиент не аутентифицируется. В TLS 1.3
                // клиент завершает СВОЮ сторону оптимистично (шлёт Finished) ДО
                // получения серверного certificate_required alert — поэтому
                // connect может вернуть Ok; отказ ловится сервером (его spawn
                // ассертит Err) либо первым чтением у клиента. Здесь просто
                // прибираем ресурс, не ассертя на клиентскую сторону.
                ro ccfg = ClientConfig.new("localhost")
                    .verification(VerificationMode.CustomRoots(fixture_cert()))
                match TlsStream.connect(conn, ccfg) {
                    Ok(s)  => {
                        consume st = s
                        match st.read_to_vec(64) { Ok(_) => {} Err(_) => {} }
                        st.close()
                    }
                    Err(_) => {}
                }
            }
        }
    }
}

test "T5-Optional: клиент С сертом принят" {
    with Net = real_net() {
        ro ch_port = Channel.new(1)
        supervised {
            spawn {
                consume lst = must_listener(TcpListener.bind(SocketAddr.loopback(0)))
                ch_port.tx.send(lst.local_port())
                ro accepted = lst.accept()
                lst.close()
                consume conn = must_tcp(accepted)
                ro scfg = ServerConfig.new(fixture_cert(), fixture_key())
                    .client_cert(ClientCertMode.Optional(client_ca()))
                consume tls = must_tls(TlsStream.accept(conn, scfg))
                tls.close()
            }
            spawn {
                ro port = match ch_port.rx.recv() { Some(p) => p  None => 0 as u16 }
                assert(port > 0)
                consume conn = must_tcp(TcpStream.connect(SocketAddr.loopback(port)))
                ro ccfg = ClientConfig.new("localhost")
                    .verification(VerificationMode.CustomRoots(fixture_cert()))
                    .client_cert(client_leaf(), client_leaf_key())
                consume tls = must_tls(TlsStream.connect(conn, ccfg))
                tls.close()
            }
        }
    }
}

test "T5-Optional: клиент БЕЗ серта тоже принят (auth опциональна)" {
    with Net = real_net() {
        ro ch_port = Channel.new(1)
        supervised {
            spawn {
                consume lst = must_listener(TcpListener.bind(SocketAddr.loopback(0)))
                ch_port.tx.send(lst.local_port())
                ro accepted = lst.accept()
                lst.close()
                consume conn = must_tcp(accepted)
                ro scfg = ServerConfig.new(fixture_cert(), fixture_key())
                    .client_cert(ClientCertMode.Optional(client_ca()))
                consume tls = must_tls(TlsStream.accept(conn, scfg))
                tls.close()
            }
            spawn {
                ro port = match ch_port.rx.recv() { Some(p) => p  None => 0 as u16 }
                assert(port > 0)
                consume conn = must_tcp(TcpStream.connect(SocketAddr.loopback(port)))
                ro ccfg = ClientConfig.new("localhost")
                    .verification(VerificationMode.CustomRoots(fixture_cert()))
                consume tls = must_tls(TlsStream.connect(conn, ccfg))
                tls.close()
            }
        }
    }
}
